
{% if section.settings.show_section %} 
  <section
    class="custom-homepage-benefits"
    style="
      background-color: {{ section.settings.background_color }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    <div class="
      {% case section.settings.page_width %}
        {% when 'full' %}
          custom-page-width-full
        {% when 'narrow' %}
          custom-page-width-narrow
        {% else %}
          page-width
      {% endcase %}
    ">

      <div class="custom-homepage-benefits__grid">

        {% for block in section.blocks %}

          <div
            class="custom-homepage-benefits__item"
            style="text-align: {{ section.settings.text_alignment }};"
            {{ block.shopify_attributes }}
          >

            {% if block.settings.icon != blank %}

              {{
                block.settings.icon
                | image_url: width: 120
                | image_tag:
                  loading: 'lazy',
                  alt: block.settings.icon_alt
              }}

            {% else %}

              {{ 'image' | placeholder_svg_tag: 'benefit-placeholder' }}

            {% endif %}

            {% if block.settings.title != blank %}
              <h3>{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p>{{ block.settings.text }}</p>
            {% endif %}

          </div>

        {% endfor %}

      </div>

    </div>

  </section>
{% endif %}

{% schema %}
{
  "name": "Custom Homepage Benefits",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show Section",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page Width",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "full",
          "label": "Full Width"
        }
      ],
      "default": "standard"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon / Image"
        },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "Icon Alt Text",
          "default": "Benefit icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Benefit Title",
          "default": "Fast Shipping"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Short Text",
          "default": "Quick delivery to your doorstep."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Custom Homepage Benefits",
      "blocks": [
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        },
        {
          "type": "benefit"
        }
      ]
    }
  ]
}
{% endschema %} 
