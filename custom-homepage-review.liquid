
<section class="custom-homepage-reviews">
  <div class="page-width">

    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>

      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="custom-homepage-reviews__grid">

      {% for block in section.blocks %}

        {% assign product = block.settings.product %}

        <div
          class="custom-homepage-review-card"
          {{ block.shopify_attributes }}
        >

          {% if block.settings.reviewer_image != blank %}
            <div class="review-card__image">
              {{
                block.settings.reviewer_image
                | image_url: width: 120
                | image_tag:
                  loading: 'lazy',
                  alt: block.settings.reviewer_name
              }}
            </div>
          {% endif %}

          <div class="review-card__stars">

            {% for i in (1..5) %}
              {% if i <= block.settings.rating %}
                ★
              {% else %}
                ☆
              {% endif %}
            {% endfor %}

          </div>

          {% if block.settings.review_text != blank %}
            <div class="review-card__text">
              "{{ block.settings.review_text }}"
            </div>
          {% endif %}

          {% if block.settings.reviewer_name != blank %}
            <h3 class="review-card__name">
              {{ block.settings.reviewer_name }}
            </h3>
          {% endif %}

          {% if product != blank %}
            <div class="review-card__product">

              <small>
                Reviewed Product:
              </small>

              <a href="{{ product.url }}">
                {{ product.title }}
              </a>

            </div>
          {% endif %}

          {% if block.settings.button_text != blank and block.settings.button_link != blank %}
            <div class="review-card__cta">

              <a
                href="{{ block.settings.button_link }}"
                class="button button--secondary"
              >
                {{ block.settings.button_text }}
              </a>

            </div>
          {% endif %}

        </div>

      {% endfor %}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Title",
      "default": "Customer Reviews"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtitle",
      "default": "See what our customers are saying."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "John Doe"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Amazing product. Highly recommended!"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "image_picker",
          "id": "reviewer_image",
          "label": "Reviewer Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Optional Product Reference"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Custom Homepage Reviews",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %} 
