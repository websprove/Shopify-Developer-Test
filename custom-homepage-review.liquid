{% if section.settings.show_section %}
<section class="custom-homepage-reviews" style="
  background-color: {{ section.settings.background_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
">
<div class="
  {% case section.settings.page_width %}
    {% when 'full' %}
      custom-page-width-full
    {% when 'narrow' %}
      custom-page-width-narrow
    {% else %}
      page-width
  {% endcase %}
">

    <div class="section-header">
      <h2>{{ section.settings.heading }}</h2>

      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="custom-homepage-reviews__grid">

      {% for block in section.blocks %}

        {% assign product = block.settings.product %}

        <div
          class="custom-homepage-review-card"
          {{ block.shopify_attributes }}
        >

          {% if block.settings.reviewer_image != blank %}
            <div class="review-card__image">
              {{
                block.settings.reviewer_image
                | image_url: width: 120
                | image_tag:
                  loading: 'lazy',
                  alt: block.settings.reviewer_name
              }}
            </div>
          {% endif %}

          <div class="review-card__stars">

            {% for i in (1..5) %}
              {% if i <= block.settings.rating %}
                ★
              {% else %}
                ☆
              {% endif %}
            {% endfor %}

          </div>

          {% if block.settings.review_text != blank %}
            <div class="review-card__text">
              "{{ block.settings.review_text }}"
            </div>
          {% endif %}

          {% if block.settings.reviewer_name != blank %}
            <h3 class="review-card__name">
              {{ block.settings.reviewer_name }}
            </h3>
          {% endif %}

          {% if product != blank %}
            <div class="review-card__product">

              <small>
                Reviewed Product:
              </small>

              <a href="{{ product.url }}">
                {{ product.title }}
              </a>

            </div>
          {% endif %}

          {% if block.settings.button_text != blank and block.settings.button_link != blank %}
            <div class="review-card__cta">

              <a
                href="{{ block.settings.button_link }}"
                class="button button--secondary"
              >
                {{ block.settings.button_text }}
              </a>

            </div>
          {% endif %}

        </div>

      {% endfor %}

    </div>

  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Title",
      "default": "Customer Reviews"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtitle",
      "default": "See what our customers are saying."
    },
    {
  "type":"checkbox",
  "id":"show_section",
  "label":"Show Section",
  "default":true
},
{
  "type":"color",
  "id":"background_color",
  "label":"Background Color",
  "default":"#ffffff"
},
{
  "type":"select",
  "id":"text_alignment",
  "label":"Text Alignment",
  "options":[
    {"value":"left","label":"Left"},
    {"value":"center","label":"Center"},
    {"value":"right","label":"Right"}
  ],
  "default":"left"
},
{
  "type":"range",
  "id":"padding_top",
  "min":0,
  "max":120,
  "step":4,
  "default":60,
  "label":"Padding Top"
},
{
  "type":"range",
  "id":"padding_bottom",
  "min":0,
  "max":120,
  "step":4,
  "default":60,
  "label":"Padding Bottom"
},
{
  "type": "select",
  "id": "page_width",
  "label": "Page Width",
  "options": [
    {
      "value": "standard",
      "label": "Standard"
    },
    {
      "value": "narrow",
      "label": "Narrow"
    },
    {
      "value": "full",
      "label": "Full Width"
    }
  ],
  "default": "standard"
}
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "John Doe"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Amazing product. Highly recommended!"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "image_picker",
          "id": "reviewer_image",
          "label": "Reviewer Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Optional Product Reference"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Custom Homepage Reviews",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %} 
